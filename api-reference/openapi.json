{
  "openapi": "3.0.3",
  "info": {
    "title": "Petstore API",
    "description": "A sample Pet Store API that demonstrates features of the OpenAPI 3.0.3 specification. You can find out more about Swagger at [https://swagger.io](https://swagger.io).",
    "termsOfService": "https://swagger.io/terms/",
    "contact": {
      "email": "apiteam@swagger.io"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://petstore.swagger.io/v2",
      "description": "Petstore production server"
    }
  ],
  "tags": [
    {
      "name": "Pet",
      "description": "Everything about your Pets"
    },
    {
      "name": "Store",
      "description": "Access to Petstore orders"
    },
    {
      "name": "User",
      "description": "Operations about users"
    }
  ],
  "paths": {
    "/pet": {
      "post": {
        "tags": ["Pet"],
        "summary": "Add a new pet to the store",
        "description": "Creates a new pet resource in the store. The pet must include a name and at least one photo URL.",
        "operationId": "addPet",
        "requestBody": {
          "description": "Pet object that needs to be added to the store",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pet"
              },
              "example": {
                "name": "Buddy",
                "category": {
                  "id": 1,
                  "name": "Dogs"
                },
                "photoUrls": ["https://example.com/buddy.jpg"],
                "tags": [
                  {
                    "id": 1,
                    "name": "friendly"
                  }
                ],
                "status": "available"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pet created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pet"
                }
              }
            }
          },
          "405": {
            "description": "Invalid input"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      },
      "put": {
        "tags": ["Pet"],
        "summary": "Update an existing pet",
        "description": "Updates a pet resource that already exists in the store. The full pet object must be provided.",
        "operationId": "updatePet",
        "requestBody": {
          "description": "Pet object that needs to be updated in the store",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pet"
              },
              "example": {
                "id": 10,
                "name": "Buddy",
                "category": {
                  "id": 1,
                  "name": "Dogs"
                },
                "photoUrls": ["https://example.com/buddy-updated.jpg"],
                "tags": [
                  {
                    "id": 1,
                    "name": "friendly"
                  }
                ],
                "status": "sold"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pet updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pet"
                }
              }
            }
          },
          "400": {
            "description": "Invalid ID supplied"
          },
          "404": {
            "description": "Pet not found"
          },
          "405": {
            "description": "Validation exception"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/pet/findByStatus": {
      "get": {
        "tags": ["Pet"],
        "summary": "Find pets by status",
        "description": "Returns all pets that match the given status. Multiple status values can be provided as comma-separated strings.",
        "operationId": "findPetsByStatus",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Status values used to filter pets",
            "required": true,
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["available", "pending", "sold"],
                "default": "available"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Pet"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid status value"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/pet/{petId}": {
      "get": {
        "tags": ["Pet"],
        "summary": "Find pet by ID",
        "description": "Returns a single pet by its unique identifier. The pet ID must be a positive integer.",
        "operationId": "getPetById",
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "description": "ID of the pet to return",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pet"
                }
              }
            }
          },
          "400": {
            "description": "Invalid ID supplied"
          },
          "404": {
            "description": "Pet not found"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      },
      "delete": {
        "tags": ["Pet"],
        "summary": "Delete a pet",
        "description": "Deletes a pet from the store by its unique identifier.",
        "operationId": "deletePet",
        "parameters": [
          {
            "name": "api_key",
            "in": "header",
            "description": "API key for authorization",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "petId",
            "in": "path",
            "description": "ID of the pet to delete",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pet deleted successfully"
          },
          "400": {
            "description": "Invalid ID supplied"
          },
          "404": {
            "description": "Pet not found"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/store/inventory": {
      "get": {
        "tags": ["Store"],
        "summary": "Returns pet inventories by status",
        "description": "Returns a map of status codes to quantities. Each key is a pet status and the value is the count of pets with that status.",
        "operationId": "getInventory",
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "example": {
                    "available": 120,
                    "pending": 4,
                    "sold": 67
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/store/order": {
      "post": {
        "tags": ["Store"],
        "summary": "Place an order for a pet",
        "description": "Creates a new purchase order in the store. Orders move through placed, approved, and delivered statuses.",
        "operationId": "placeOrder",
        "requestBody": {
          "description": "Order object to place in the store",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Order"
              },
              "example": {
                "petId": 10,
                "quantity": 1,
                "shipDate": "2026-04-01T10:00:00.000Z",
                "status": "placed",
                "complete": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order placed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Invalid order"
          }
        }
      }
    },
    "/store/order/{orderId}": {
      "get": {
        "tags": ["Store"],
        "summary": "Find purchase order by ID",
        "description": "Returns the details of a purchase order. Order IDs between 1 and 10 are pre-populated for testing.",
        "operationId": "getOrderById",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "description": "ID of the order to retrieve",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 1,
              "maximum": 10,
              "example": 3
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Invalid ID supplied"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/user": {
      "post": {
        "tags": ["User"],
        "summary": "Create a new user",
        "description": "Creates a new user account. This can only be done by an authenticated user.",
        "operationId": "createUser",
        "requestBody": {
          "description": "User object to create",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              },
              "example": {
                "username": "johndoe",
                "firstName": "John",
                "lastName": "Doe",
                "email": "john.doe@example.com",
                "password": "secret123",
                "phone": "+1-555-0100",
                "userStatus": 1
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Invalid user data supplied"
          }
        }
      }
    },
    "/user/login": {
      "get": {
        "tags": ["User"],
        "summary": "Log user into the system",
        "description": "Authenticates a user with username and password credentials. Returns a session token in the response header.",
        "operationId": "loginUser",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "description": "The username for login",
            "required": true,
            "schema": {
              "type": "string",
              "example": "johndoe"
            }
          },
          {
            "name": "password",
            "in": "query",
            "description": "The password for login in clear text",
            "required": true,
            "schema": {
              "type": "string",
              "example": "secret123"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "headers": {
              "X-Rate-Limit": {
                "description": "Number of allowed requests per hour for the user",
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              },
              "X-Expires-After": {
                "description": "Date and time in UTC when the token expires",
                "schema": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": "logged in user session:1648473600000"
                }
              }
            }
          },
          "400": {
            "description": "Invalid username or password supplied"
          }
        }
      }
    },
    "/user/{username}": {
      "get": {
        "tags": ["User"],
        "summary": "Get user by username",
        "description": "Returns the full user profile for the given username.",
        "operationId": "getUserByName",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "description": "The username of the user to fetch",
            "required": true,
            "schema": {
              "type": "string",
              "example": "johndoe"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Invalid username supplied"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Category": {
        "type": "object",
        "description": "A category that a pet belongs to.",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for the category",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "Name of the category",
            "example": "Dogs"
          }
        }
      },
      "Tag": {
        "type": "object",
        "description": "A tag that can be attached to a pet for filtering and search.",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for the tag",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "Label for the tag",
            "example": "friendly"
          }
        }
      },
      "Pet": {
        "type": "object",
        "description": "A pet available in the store.",
        "required": ["name", "photoUrls"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for the pet, assigned by the server",
            "example": 10
          },
          "name": {
            "type": "string",
            "description": "Display name of the pet",
            "example": "Buddy"
          },
          "category": {
            "$ref": "#/components/schemas/Category"
          },
          "photoUrls": {
            "type": "array",
            "description": "URLs to photos of the pet",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "example": ["https://example.com/buddy.jpg"]
          },
          "tags": {
            "type": "array",
            "description": "Tags attached to this pet for filtering",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          },
          "status": {
            "type": "string",
            "description": "Availability status of the pet in the store",
            "enum": ["available", "pending", "sold"],
            "example": "available"
          }
        }
      },
      "Order": {
        "type": "object",
        "description": "A purchase order for a pet from the store.",
        "required": ["petId", "quantity"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for the order, assigned by the server",
            "example": 1
          },
          "petId": {
            "type": "integer",
            "format": "int64",
            "description": "ID of the pet being ordered",
            "example": 10
          },
          "quantity": {
            "type": "integer",
            "format": "int32",
            "description": "Number of pets ordered",
            "minimum": 1,
            "example": 1
          },
          "shipDate": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated date and time for shipping",
            "example": "2026-04-01T10:00:00.000Z"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order",
            "enum": ["placed", "approved", "delivered"],
            "example": "placed"
          },
          "complete": {
            "type": "boolean",
            "description": "Whether the order has been completed",
            "default": false,
            "example": false
          }
        }
      },
      "User": {
        "type": "object",
        "description": "A registered user of the pet store.",
        "required": ["username", "email", "password"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for the user, assigned by the server",
            "example": 100
          },
          "username": {
            "type": "string",
            "description": "Login username",
            "example": "johndoe"
          },
          "firstName": {
            "type": "string",
            "description": "User's first name",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "description": "User's last name",
            "example": "Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address",
            "example": "john.doe@example.com"
          },
          "password": {
            "type": "string",
            "description": "User's password",
            "example": "secret123"
          },
          "phone": {
            "type": "string",
            "description": "User's phone number",
            "example": "+1-555-0100"
          },
          "userStatus": {
            "type": "integer",
            "format": "int32",
            "description": "Account status. 1 = active, 0 = inactive.",
            "example": 1
          }
        }
      }
    },
    "securitySchemes": {
      "api_key": {
        "type": "apiKey",
        "name": "api_key",
        "in": "header",
        "description": "API key passed in the request header for authentication"
      }
    }
  }
}
